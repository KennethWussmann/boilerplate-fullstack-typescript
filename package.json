{
  "name": "boilerplate",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo run build:watch",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "codegen": "turbo run codegen",
    "clean": "rm -rf ./apps/*/dist && rm -rf ./libs/*/dist",
