{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				"./dist"
			]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"build:watch": {
			"persistent": true,
			"cache": false
		},
		"test:watch": {
			"persistent": true,
			"cache": false
		},
		"test": {
			"persistent": true,
			"cache": false
		},
		"codegen": {
			"cache": false
		}
	}
}