    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/graphql-modules-preset": "^5.1.0",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@envelop/graphql-modules": "^9.0.0",
