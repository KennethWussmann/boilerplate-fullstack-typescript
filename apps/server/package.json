    "express": "^5.1.0",
    "glob": "^11.1.0",
    "graphql": "^16.12.0",
    "graphql-modules": "^3.0.0",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^6.0.6",
    "graphql-yoga": "^5.16.2",
    "parse-duration": "^2.1.4",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.3",
