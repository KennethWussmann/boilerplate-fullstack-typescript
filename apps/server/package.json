{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "pnpm codegen && tsx watch src/run.ts",
    "build": "pnpm codegen && tsc && pnpm copy-graphql",
    "build:watch": "pnpm codegen && tsc --watch",
    "copy-graphql": "cd src && find . -name '*.graphql' -exec sh -c 'mkdir -p ../dist/$(dirname {}) && cp {} ../dist/{}' \\;",
    "codegen": "graphql-codegen && tsx scripts/update-config-options-doc.ts",
    "drizzle-kit": "CONFIG_JSON=$(tsx --no-warnings './scripts/print-config.ts') drizzle-kit",
    "db:migrate": "pnpm drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "pnpm drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "pnpm drizzle-kit generate --config=drizzle.config.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts && pnpm db:migrate && pnpm db:seed",
    "db:clear": "tsx scripts/reset-db.ts && pnpm db:migrate",
    "gql": "tsx scripts/gql.ts"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/graphql-modules-preset": "^5.1.2",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bull-board/api": "^6.16.2",
    "@bull-board/express": "^6.16.2",
    "@envelop/graphql-modules": "^9.0.0",
    "@graphql-tools/load-files": "^7.0.1",
    "bullmq": "^5.66.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "glob": "^13.0.0",
    "graphql": "^16.12.0",
    "graphql-modules": "3.1.1",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^6.0.6",
    "graphql-yoga": "^5.18.0",
    "parse-duration": "^2.1.5",
    "postgres": "^3.4.8",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  }
}